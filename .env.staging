# Staging Environment Configuration
DB_NAME=employee_scheduling_staging
DB_USER=postgres
DB_PASSWORD=staging_password_change_me

JWT_SECRET=staging_jwt_secret_change_me
JWT_EXPIRATION=7d

BACKEND_CORS_ORIGIN=http://staging-ip:3000
FRONTEND_API_URL=http://staging-ip:5000/api

SMTP_HOST=smtp-mail.outlook.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@staging.local

NODE_ENV=staging
